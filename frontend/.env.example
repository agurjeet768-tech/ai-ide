# Copy this to .env.local and fill in your values

# Your HuggingFace Space URL (after deploying backend)
# Example: https://yourusername-ai-ide-backend.hf.space
NEXT_PUBLIC_BACKEND_URL=https://YOUR_HF_USERNAME-ai-ide-backend.hf.space

# Optional: Your HF username (for display)
NEXT_PUBLIC_HF_USERNAME=your_hf_username
